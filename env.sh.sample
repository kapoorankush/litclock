# OpenWeatherMap API key (optional — leave blank to use free Open-Meteo provider)
# export OPENWEATHERMAP_APIKEY=

# Weather: master toggle. When false, the weather row is hidden and no API
# calls are made. The location fields below are still preserved across an
# off->on toggle so the user doesn't have to re-enter them.
export WEATHER_ENABLED=true

# Austin, Texas coordinates
export WEATHER_LATITUDE=30.27
export WEATHER_LONGITUDE=-97.74

# Human-readable location name shown on the Status tab (e.g. "Austin, TX").
# Populated by the Settings tab when geocoding succeeds; ignored if blank.
export WEATHER_LOCATION_NAME=

# Units: "imperial" for Fahrenheit, "metric" for Celsius
export WEATHER_UNITS=imperial

# Location mode (#337 A1). "auto" = on-boot service re-runs IP-geolocation
# and may update lat/lon/name/units/tz; "specific" = user-set values are
# preserved across reboots (the on-boot reresolve service no-ops). Pre-S2
# envs without this key default to "auto" on read.
export WEATHER_LOCATION_MODE=auto

# Last-detected IP-geolocation country (#337 A6.1). ISO 3166-1 alpha-2 or
# empty when IP-geo hasn't run successfully. Used by the on-boot reresolve
# service AND the PWA save paths to detect country changes (and only then
# overwrite WEATHER_UNITS to the new country default). Without this key,
# units would be clobbered on every boot for users who manually picked
# non-default units in their actual country.
export WEATHER_IP_COUNTRY=

# How long, in seconds, to cache weather for
export WEATHER_TTL=3600

# Allow NSFW quotes (content with profanity, violence, or adult themes)
# Set to "true" to enable, "false" to disable (default: false)
export ALLOW_NSFW_QUOTES=false

# #416 PR3c (F31) — opt-in toggle for the diagnostics shortcut ribbon's
# full-label state. Default false → dots-three icon only (owner-persona
# protection per OV-D-C). True → 'Live diagnostics' label expanded.
# Flippable via PWA Settings → Advanced.
export SHOW_DIAGNOSTICS_SHORTCUT=false

# Gift mode (#280): the welcome message a gifter wants painted on the
# e-ink when the recipient first unboxes the device. Persisted here as
# a draft — the Control PWA Settings tab "Prepare for Gifting" section
# is the canonical editor. Triggering /api/system/prepare-for-gift
# wipes WiFi, paints this text (or a default "Welcome to LitClock" if
# empty), and powers off. The recipient sees the welcome until they
# complete first-boot setup, at which point it's cleared automatically.
export GIFT_MODE_MESSAGE=

# --- Advanced Settings (uncomment to override defaults) ---

# Hour (0-23) to do a full display clear to remove ghosting (default: 2)
# export DISPLAY_CLEAR_HOUR=2

# Weather API request timeout in seconds (default: 15)
# export WEATHER_API_TIMEOUT=15

# Log level for Python scripts (default: WARNING)
# export LOG_LEVEL=WARNING
